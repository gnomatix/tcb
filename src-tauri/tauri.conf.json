{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TCB, M.D.",
  "version": "0.1.0",
  "identifier": "com.gnomatix.tcb",
  "mainBinaryName": "tcb",
  "build": {
    "frontendDist": "../WebAssets"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TCB, M.D.",
        "width": 1000,
        "height": 720,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true,
        "zoomHotkeysEnabled": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown text document",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEOUU1Njk1Mzc0QUREQTkKUldTcDNVbzNsVmFlUGFUZHhCT2NHamdXRUt0a0ZWdnFUT2NWZC9NdGFHZ0FDaHgzUUo0TWJxUDkK",
      "endpoints": [
        "https://illumignoti.gnomatix.com/latest.json"
      ],
      "windows": { "installMode": "passive" }
    }
  }
}
